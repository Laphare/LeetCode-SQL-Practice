# Write your MySQL query statement below
WITH per_customer AS (SELECT pp.user_id,pro.category
FROM ProductPurchases pp
INNER JOIN ProductInfo pro
ON pp.product_id =pro.product_id
WHERE pp.quantity>0
)

SELECT 
p1.category AS category1,
p2.category AS category2,
COUNT(DISTINCT p1.user_id)AS customer_count
FROM per_customer p1
INNER JOIN per_customer p2
ON p1.user_id = p2.user_id
AND p1.category < p2.category
GROUP BY p1.category,p2.category
HAVING COUNT(DISTINCT p1.user_id) >= 3
ORDER BY customer_count DESC,category1 ASC, category2 ASC
