WITH total_sale AS (
SELECT 
EXTRACT(YEAR FROM transaction_date) AS year,
product_id,
SUM(spend) AS curr_year_spend
FROM user_transactions
GROUP BY EXTRACT(YEAR FROM transaction_date),product_id),

with_prev_year AS (SELECT *,
LAG(year) OVER(PARTITION BY product_id ORDER BY year) AS prev_year,
LAG(curr_year_spend) OVER(PARTITION BY product_id ORDER BY year) AS prev_year_spend
FROM total_sale)

SELECT 
    year,
    product_id,
    curr_year_spend,
    CASE 
        WHEN year - prev_year = 1 THEN prev_year_spend 
        ELSE NULL 
    END AS prev_year_spend,
    
    CASE 
        WHEN year - prev_year = 1 THEN ROUND((curr_year_spend - prev_year_spend) / prev_year_spend * 100.0, 2)
        ELSE NULL 
    END AS yoy_rate
FROM with_prev_year
