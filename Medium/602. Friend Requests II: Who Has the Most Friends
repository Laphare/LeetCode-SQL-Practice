WITH all_id AS (
    SELECT requester_id AS id FROM RequestAccepted
    UNION ALL
    SELECT accepter_id AS id FROM RequestAccepted
),
rank_list AS(
    SELECT id,
    RANK()OVER(ORDER BY COUNT(*) DESC) AS rn,
    COUNT(*) AS num
    FROM all_id
    GROUP BY id
)
SELECT id, num
FROM rank_list
WHERE rn=1
