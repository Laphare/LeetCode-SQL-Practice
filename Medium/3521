WITH purchased_t AS
(    SELECT 
        p1.product_id AS product1_id,
        p2.product_id AS product2_id,
        COUNT(DISTINCT p1.user_id) AS customer_count
    FROM 
        ProductPurchases p1
    INNER JOIN 
        ProductPurchases p2 ON p1.user_id = p2.user_id
    WHERE 
        p1.product_id < p2.product_id
    GROUP BY 
        p1.product_id, p2.product_id
    HAVING COUNT(DISTINCT p1.user_id)>=3)

SELECT t.product1_id,t.product2_id,
i1.category AS product1_category,
i2.category AS product2_category,
t.customer_count
FROM purchased_t t
INNER JOIN ProductInfo i1
ON t.product1_id =i1.product_id
INNER JOIN ProductInfo i2
ON t.product2_id =i2.product_id
ORDER BY t.customer_count DESC , t.product1_id, t.product2_id
